# FlashRoute Production Environment Variables
# Copy this file to .env and fill in the values.

# =============================================================================
# REQUIRED — Must be set for any environment
# =============================================================================

NODE_ENV=production

# Database
DATABASE_URL=postgresql://flashroute:CHANGE_ME@localhost:5432/flashroute
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Authentication (generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_SECRET
COOKIE_SECRET=CHANGE_ME_32_CHAR_SECRET
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_SECRET

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend (used for CORS and email links)
FRONTEND_URL=https://app.flashroute.com

# =============================================================================
# OPTIONAL — Required only for specific features
# =============================================================================

# Execution (Phase F — not yet enabled)
# EXECUTOR_PRIVATE_KEY=0x...
# PROFIT_SWEEP_ADDRESS=0x...
# FLASHBOTS_AUTH_SIGNER_KEY=0x...
# EXECUTION_ENABLED=false

# Blockchain RPC (required for live opportunity feeds)
# CHAIN_RPC_URL_ETHEREUM=https://...
# CHAIN_RPC_URL_ARBITRUM=https://...

# Email (Resend transactional email)
# RESEND_API_KEY=re_...

# Operational
# HEALTHCHECK_SHARED_SECRET=
# MAINTENANCE_MODE=false
