{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@flashroute/shared": ["packages/shared/src/index.ts"],
      "@flashroute/shared/*": ["packages/shared/src/*"],
      "@flashroute/config": ["packages/config/src/index.ts"],
      "@flashroute/config/*": ["packages/config/src/*"],
      "@flashroute/db": ["packages/db/src/client.ts"],
      "@flashroute/db/*": ["packages/db/src/*"],
      "@flashroute/ui": ["packages/ui/src/index.ts"],
      "@flashroute/ui/*": ["packages/ui/src/*"],
      "@flashroute/blockchain": ["packages/blockchain/src/index.ts"],
      "@flashroute/blockchain/*": ["packages/blockchain/src/*"],
      "@flashroute/contracts": ["packages/contracts"],
      "@flashroute/contracts/*": ["packages/contracts/*"]
    }
  }
}
